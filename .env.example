# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Generate a password hash:
#   npm run setup-password yourPasswordHere
# Then paste the output line below.
ADMIN_PASSWORD_HASH=$2a$12$...

# Generate a random secret (e.g. openssl rand -hex 32):
JWT_SECRET=change_me_to_a_long_random_string

# Optional: restrict CORS to your domain
# ALLOWED_ORIGIN=https://alanhurtarte.com

# Optional: change the port (default 3000)
# PORT=3000
